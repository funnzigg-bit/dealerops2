generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
  AFTERSALES
}

enum VehicleStatus {
  IN_STOCK
  RESERVED
  SOLD
  IN_PREP
  AT_GARAGE
  DELIVERED
}

enum VehicleLocation {
  FORECOURT
  WORKSHOP
  EXTERNAL_GARAGE
  CUSTOMER
  DELIVERED
  STORAGE
}

enum DealStage {
  ENQUIRY
  TEST_DRIVE_BOOKED
  NEGOTIATION
  DEPOSIT_TAKEN
  FINANCE_PENDING
  READY_FOR_COLLECTION
  COMPLETED
  CANCELLED
}

enum FinanceStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  PAID_OUT
}

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  CLAIMED
}

enum AftersalesPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AftersalesStatus {
  NEW
  UNDER_REVIEW
  APPROVED
  IN_REPAIR
  AWAITING_PARTS
  RESOLVED
  REJECTED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum CommunicationType {
  CALL
  EMAIL
  SMS
  WHATSAPP
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  name                String
  passwordHash        String
  role                Role
  mobile              String?
  active              Boolean            @default(true)
  profileImageUrl     String?
  lastLoginAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  deals               Deal[]             @relation("SalespersonDeals")
  assignedTasks       Task[]             @relation("TaskAssigned")
  createdTasks        Task[]             @relation("TaskCreated")
  aftersalesCases     AftersalesCase[]   @relation("CaseAssigned")
  communications      CommunicationLog[]
  auditLogs           AuditLog[]
  locationLogs        VehicleLocationLog[]
  dealNotes           DealNote[]
  aftersalesNotes     AftersalesNote[]

  @@index([role])
  @@index([deletedAt])
}

model Vehicle {
  id                  String               @id @default(cuid())
  registration        String               @unique
  vin                 String               @unique
  stockNumber         String               @unique
  make                String
  model               String
  derivative          String?
  year                Int
  mileage             Int
  fuelType            String
  transmission        String
  engineSize          String?
  colour              String?
  bodyStyle           String?
  doors               Int?
  seats               Int?
  purchaseDate        DateTime?
  purchasePrice       Decimal?             @db.Decimal(10, 2)
  prepCost            Decimal?             @db.Decimal(10, 2)
  advertisedPrice     Decimal?             @db.Decimal(10, 2)
  minimumPrice        Decimal?             @db.Decimal(10, 2)
  salePrice           Decimal?             @db.Decimal(10, 2)
  status              VehicleStatus        @default(IN_STOCK)
  source              String?
  supplier            String?
  location            VehicleLocation      @default(FORECOURT)
  motExpiry           DateTime?
  serviceHistory      String?
  keyCount            Int?                 @default(2)
  notes               String?
  deliveredAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  images              VehicleImage[]
  documents           VehicleDocument[]
  deals               Deal[]
  warranties          Warranty[]
  aftersalesCases     AftersalesCase[]
  locationLogs        VehicleLocationLog[]
  tasks               Task[]
  communications      CommunicationLog[]

  @@index([status])
  @@index([location])
  @@index([deletedAt])
}

model VehicleImage {
  id                  String   @id @default(cuid())
  vehicleId           String
  url                 String
  alt                 String?
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  vehicle             Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model VehicleDocument {
  id                  String   @id @default(cuid())
  vehicleId           String
  fileName            String
  fileUrl             String
  mimeType            String?
  category            String?
  uploadedAt          DateTime @default(now())
  vehicle             Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Customer {
  id                  String             @id @default(cuid())
  fullName            String
  mobile              String
  email               String?
  address             String?
  townCity            String?
  postcode            String?
  dateOfBirth         DateTime?
  drivingLicence      String?
  notes               String?
  marketingConsent    Boolean            @default(false)
  preferredContact    String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  deals               Deal[]
  financeApplications FinanceApplication[]
  invoices            Invoice[]
  warranties          Warranty[]
  aftersalesCases     AftersalesCase[]
  tasks               Task[]
  communications      CommunicationLog[]

  @@index([fullName])
  @@index([mobile])
  @@index([deletedAt])
}

model Deal {
  id                  String                @id @default(cuid())
  reference           String                @unique
  customerId          String
  vehicleId           String
  salespersonId       String
  stage               DealStage             @default(ENQUIRY)
  deposit             Decimal?              @db.Decimal(10, 2)
  agreedPrice         Decimal?              @db.Decimal(10, 2)
  partExchangeValue   Decimal?              @db.Decimal(10, 2)
  addOnsValue         Decimal?              @db.Decimal(10, 2)
  warrantySold        Boolean               @default(false)
  financePending      Boolean               @default(false)
  deliveryMethod      String?
  collectionDate      DateTime?
  notes               String?
  completedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  customer            Customer              @relation(fields: [customerId], references: [id])
  vehicle             Vehicle               @relation(fields: [vehicleId], references: [id])
  salesperson         User                  @relation("SalespersonDeals", fields: [salespersonId], references: [id])
  financeApplications FinanceApplication[]
  invoice             Invoice?
  dealNotes           DealNote[]
  warranties          Warranty[]
  communications      CommunicationLog[]
  tasks               Task[]
  complianceEvidence  ComplianceEvidence[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([salespersonId])
  @@index([stage])
  @@index([deletedAt])
}

model DealNote {
  id                  String   @id @default(cuid())
  dealId              String
  userId              String
  note                String
  internal            Boolean  @default(true)
  createdAt           DateTime @default(now())
  deal                Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id])

  @@index([dealId])
}

model FinanceProvider {
  id                  String               @id @default(cuid())
  name                String               @unique
  contactEmail        String?
  contactPhone        String?
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  applications        FinanceApplication[]
}

model FinanceApplication {
  id                  String         @id @default(cuid())
  dealId              String
  customerId          String
  providerId          String
  proposalReference   String
  amountFinanced      Decimal        @db.Decimal(10, 2)
  deposit             Decimal?       @db.Decimal(10, 2)
  apr                 Decimal?       @db.Decimal(5, 2)
  termMonths          Int?
  commission          Decimal?       @db.Decimal(10, 2)
  payout              Decimal?       @db.Decimal(10, 2)
  status              FinanceStatus  @default(DRAFT)
  submittedAt         DateTime?
  acceptedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deal                Deal           @relation(fields: [dealId], references: [id])
  customer            Customer       @relation(fields: [customerId], references: [id])
  provider            FinanceProvider @relation(fields: [providerId], references: [id])

  @@index([dealId])
  @@index([customerId])
  @@index([providerId])
  @@index([status])
}

model Invoice {
  id                  String         @id @default(cuid())
  invoiceNumber       String         @unique
  dealId              String         @unique
  customerId          String
  subtotal            Decimal        @db.Decimal(10, 2)
  vatAmount           Decimal        @db.Decimal(10, 2)
  total               Decimal        @db.Decimal(10, 2)
  depositPaid         Decimal        @db.Decimal(10, 2)
  balanceDue          Decimal        @db.Decimal(10, 2)
  paymentMethod       String?
  notes               String?
  status              InvoiceStatus  @default(UNPAID)
  issuedAt            DateTime       @default(now())
  paidAt              DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deal                Deal           @relation(fields: [dealId], references: [id])
  customer            Customer       @relation(fields: [customerId], references: [id])
  items               InvoiceItem[]

  @@index([status])
  @@index([issuedAt])
}

model InvoiceItem {
  id                  String   @id @default(cuid())
  invoiceId           String
  description         String
  quantity            Int      @default(1)
  unitPrice           Decimal  @db.Decimal(10, 2)
  lineTotal           Decimal  @db.Decimal(10, 2)
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model WarrantyProvider {
  id                  String     @id @default(cuid())
  name                String     @unique
  contactEmail        String?
  contactPhone        String?
  active              Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  warranties          Warranty[]
}

model Warranty {
  id                  String         @id @default(cuid())
  warrantyNumber      String         @unique
  providerId          String
  dealId              String?
  vehicleId           String
  customerId          String
  durationMonths      Int
  startDate           DateTime
  endDate             DateTime
  cost                Decimal        @db.Decimal(10, 2)
  retailPrice         Decimal        @db.Decimal(10, 2)
  status              WarrantyStatus @default(ACTIVE)
  coverageNotes       String?
  documentUrl         String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  provider            WarrantyProvider @relation(fields: [providerId], references: [id])
  deal                Deal?          @relation(fields: [dealId], references: [id])
  vehicle             Vehicle        @relation(fields: [vehicleId], references: [id])
  customer            Customer       @relation(fields: [customerId], references: [id])
  aftersalesCases     AftersalesCase[]
  tasks               Task[]

  @@index([providerId])
  @@index([vehicleId])
  @@index([customerId])
  @@index([status])
}

model Garage {
  id                  String          @id @default(cuid())
  name                String
  contactName         String?
  mobile              String?
  email               String?
  address             String?
  townCity            String?
  postcode            String?
  active              Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  aftersalesCases     AftersalesCase[]
}

model AftersalesCase {
  id                  String             @id @default(cuid())
  reference           String             @unique
  vehicleId           String
  customerId          String
  warrantyId          String?
  assignedToId        String?
  garageId            String?
  issueTitle          String
  description         String
  reportedDate        DateTime
  priority            AftersalesPriority @default(MEDIUM)
  status              AftersalesStatus   @default(NEW)
  outcome             String?
  estimatedCost       Decimal?           @db.Decimal(10, 2)
  actualCost          Decimal?           @db.Decimal(10, 2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id])
  customer            Customer           @relation(fields: [customerId], references: [id])
  warranty            Warranty?          @relation(fields: [warrantyId], references: [id])
  assignedTo          User?              @relation("CaseAssigned", fields: [assignedToId], references: [id])
  garage              Garage?            @relation(fields: [garageId], references: [id])
  notes               AftersalesNote[]
  tasks               Task[]
  complianceEvidence  ComplianceEvidence[]

  @@index([vehicleId])
  @@index([customerId])
  @@index([status])
  @@index([priority])
}

model AftersalesNote {
  id                  String        @id @default(cuid())
  aftersalesCaseId    String
  userId              String
  note                String
  createdAt           DateTime      @default(now())
  aftersalesCase      AftersalesCase @relation(fields: [aftersalesCaseId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id])

  @@index([aftersalesCaseId])
}

model VehicleLocationLog {
  id                  String          @id @default(cuid())
  vehicleId           String
  fromLocation        VehicleLocation
  toLocation          VehicleLocation
  reason              String
  notes               String?
  movedAt             DateTime        @default(now())
  userId              String
  vehicle             Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user                User            @relation(fields: [userId], references: [id])

  @@index([vehicleId])
  @@index([movedAt])
}

model Task {
  id                  String         @id @default(cuid())
  title               String
  description         String?
  dueDate             DateTime?
  priority            TaskPriority   @default(MEDIUM)
  status              TaskStatus     @default(TODO)
  assignedToId        String?
  createdById         String
  vehicleId           String?
  customerId          String?
  dealId              String?
  warrantyId          String?
  aftersalesCaseId    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  assignedTo          User?          @relation("TaskAssigned", fields: [assignedToId], references: [id])
  createdBy           User           @relation("TaskCreated", fields: [createdById], references: [id])
  vehicle             Vehicle?       @relation(fields: [vehicleId], references: [id])
  customer            Customer?      @relation(fields: [customerId], references: [id])
  deal                Deal?          @relation(fields: [dealId], references: [id])
  warranty            Warranty?      @relation(fields: [warrantyId], references: [id])
  aftersalesCase      AftersalesCase? @relation(fields: [aftersalesCaseId], references: [id])

  @@index([status])
  @@index([dueDate])
}

model CommunicationLog {
  id                  String                 @id @default(cuid())
  type                CommunicationType
  direction           CommunicationDirection
  subject             String?
  notes               String
  customerId          String
  vehicleId           String?
  dealId              String?
  userId              String
  createdAt           DateTime               @default(now())
  customer            Customer               @relation(fields: [customerId], references: [id])
  vehicle             Vehicle?               @relation(fields: [vehicleId], references: [id])
  deal                Deal?                  @relation(fields: [dealId], references: [id])
  user                User                   @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}

model AuditLog {
  id                  String   @id @default(cuid())
  entityType          String
  entityId            String
  action              String
  beforeData          Json?
  afterData           Json?
  meta                Json?
  userId              String?
  createdAt           DateTime @default(now())
  immutableHash       String
  user                User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model ComplianceEvidence {
  id                  String        @id @default(cuid())
  dealId              String?
  aftersalesCaseId    String?
  title               String
  details             String
  documentUrl         String?
  acknowledgedAt      DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deal                Deal?         @relation(fields: [dealId], references: [id])
  aftersalesCase      AftersalesCase? @relation(fields: [aftersalesCaseId], references: [id])
}

model DealerSettings {
  id                  String   @id @default(cuid())
  dealershipName      String
  legalName           String?
  vatNumber           String?
  addressLine1        String?
  addressLine2        String?
  townCity            String?
  postcode            String?
  phone               String?
  email               String?
  invoicePrefix       String   @default("INV")
  warrantyPrefix      String   @default("WAR")
  logoUrl             String?
  invoiceTerms        String?
  warrantyFooter      String?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}
